rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // DRIVERS collection
    // - A driver can only read/write their OWN document
    //   (identified by phone number as doc ID)
    // - Admin (custom claim) can read/write ALL
    // ──────────────────────────────────────────────
    match /drivers/{driverId} {
      // Driver reads only their own doc
      allow read: if request.auth != null
                  && (request.auth.token.phone_number == driverId
                      || request.auth.uid == driverId
                      || request.auth.token.admin == true);

      // Driver can update their own location/status only (not balance/freeTrips)
      allow update: if request.auth != null
                    && (request.auth.token.phone_number == driverId || request.auth.uid == driverId)
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'freeTrips']));

      // Only admin can create, delete, or update sensitive fields
      allow create, delete: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true;
    }

    // ──────────────────────────────────────────────
    // DRIVERS LOCATION collection (Real-time tracking)
    // - Riders (anyone authed) can read
    // - Drivers can only update their own location
    // ──────────────────────────────────────────────
    match /drivers_location/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == driverId || request.auth.token.phone_number == driverId || request.auth.token.admin == true);
    }

    // ──────────────────────────────────────────────
    // ORDERS collection
    // - Any authenticated user can create an order (rider)
    // - Driver can update orders they are assigned to
    // - Admin can do everything
    // ──────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.driverId == request.auth.token.phone_number
                        || resource.data.driverId == null
                        || request.auth.token.admin == true);
      allow delete: if request.auth.token.admin == true;
    }

    // ──────────────────────────────────────────────
    // USERS collection — riders, private to each user
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth.token.admin == true;
    }

    // ──────────────────────────────────────────────
    // Deny all other access by default
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth.token.admin == true;
    }
  }
}
